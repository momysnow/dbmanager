# Custom Caddy build with DNS-01 ACME plugins for major providers.
# Builder stage uses xcaddy to bake plugins into a single static binary.
FROM caddy:2.10-builder AS builder

# Force a recent Go toolchain — caddy-dns/route53 requires Go >= 1.25.
ENV GOTOOLCHAIN=go1.25.0

RUN xcaddy build \
    --with github.com/caddy-dns/cloudflare \
    --with github.com/caddy-dns/route53 \
    --with github.com/caddy-dns/digitalocean \
    --with github.com/caddy-dns/gandi \
    --with github.com/caddy-dns/duckdns

FROM caddy:2.10

COPY --from=builder /usr/bin/caddy /usr/bin/caddy

# Caddyfile is generated by the dbmanager backend and bind-mounted at runtime.
# Admin API is bound to 0.0.0.0:2019 so the backend container can reach it.
EXPOSE 80 443 2019
