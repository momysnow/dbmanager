# Custom Caddy build with DNS-01 ACME plugins for major providers.
# Builder stage uses xcaddy to bake plugins into a single static binary.
#
# Plugins are pinned to specific versions / commit pseudo-versions so a
# malicious tag republish or a force-pushed branch cannot slip into a
# rebuild unchecked. Bump the version, rebuild, run the proxy integration
# tests, then commit.
FROM caddy:2.10-builder AS builder

# Force a recent Go toolchain — caddy-dns/route53 requires Go >= 1.25.
ENV GOTOOLCHAIN=go1.25.0

RUN xcaddy build \
    --with github.com/caddy-dns/cloudflare@v0.2.4 \
    --with github.com/caddy-dns/route53@v1.6.2 \
    --with github.com/caddy-dns/digitalocean@v0.0.0-20250606074528-04bde2867106 \
    --with github.com/caddy-dns/gandi@v1.1.0 \
    --with github.com/caddy-dns/duckdns@v0.5.0

FROM caddy:2.10

COPY --from=builder /usr/bin/caddy /usr/bin/caddy
COPY entrypoint.sh /usr/local/bin/dbmgr-caddy-entrypoint.sh
RUN chmod +x /usr/local/bin/dbmgr-caddy-entrypoint.sh

# Caddyfile is generated by the dbmanager backend and bind-mounted at runtime.
# Admin API listens on :2019 internally; reachable only inside the docker
# network (no ports mapping), and further restricted via `origins` in Caddyfile.
EXPOSE 80 443

# Override the upstream caddy ENTRYPOINT so DNS-provider tokens can be
# sourced from `${NAME}_FILE` files (docker / k8s secrets) without the
# plaintext value ever appearing in the process environment.
ENTRYPOINT ["/usr/local/bin/dbmgr-caddy-entrypoint.sh"]
CMD ["run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
