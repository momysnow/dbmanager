FROM node:26-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install --legacy-peer-deps

COPY . .

RUN chmod +x docker-entrypoint.sh \
    && chown -R node:node /app

# Drop root: alpine images ship a non-root `node` user (uid 1000).
USER node

EXPOSE 5173

ENTRYPOINT ["./docker-entrypoint.sh"]
