# DBManager environment variables
# ⚠ Replace ALL placeholder values before starting the API. The app refuses
#   to boot if it detects known placeholders (admin/admin, change-me, etc.).

DBMANAGER_CREATE_ADMIN=true
DBMANAGER_ADMIN_USER=admin
# Set a strong password (>=8 chars). Will be force-changed on first login.
# Leave empty to have one auto-generated and printed once on first boot.
DBMANAGER_ADMIN_PASSWORD=

# JWT secret for API tokens. REQUIRED in production.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DBMANAGER_JWT_SECRET=

# Master key for encrypting sensitive config values (Fernet key).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DBMANAGER_MASTER_KEY=

# ── DNS-01 ACME provider tokens ─────────────────────────────────────────────
# Caddy reads these via {env.NAME} when issuing Let's Encrypt certs through
# DNS-01 challenge. Only set the one matching your provider.
#
# Two options for each token:
#   1. Plain env var (simplest, dev/single-host):
#        CF_API_TOKEN=cloudflare_token_here
#      Caveat: visible in `docker inspect` and /proc/1/environ.
#   2. Secret file (recommended for prod / Swarm / k8s):
#        CF_API_TOKEN_FILE=/run/secrets/cf_api_token
#      The caddy entrypoint reads the file and exports the token only into
#      Caddy's process environment. Mount the secret via docker secrets,
#      a bind-mounted file with mode 0400, or a k8s secret volume.
#
# CF_API_TOKEN=
# CF_API_TOKEN_FILE=
# AWS_ACCESS_KEY_ID=
# AWS_ACCESS_KEY_ID_FILE=
# AWS_SECRET_ACCESS_KEY=
# AWS_SECRET_ACCESS_KEY_FILE=
# AWS_REGION=
# DO_AUTH_TOKEN=
# DO_AUTH_TOKEN_FILE=
# GANDI_API_TOKEN=
# GANDI_API_TOKEN_FILE=
# DUCKDNS_API_TOKEN=
# DUCKDNS_API_TOKEN_FILE=
