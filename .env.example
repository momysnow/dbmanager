# ═══════════════════════════════════════════════════════════════
# DBManager - Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# ── Admin Account ─────────────────────────────────────────────
# Auto-create admin user on first start
DBMANAGER_CREATE_ADMIN=true
DBMANAGER_ADMIN_USER=admin
DBMANAGER_ADMIN_PASSWORD=admin

# ── Security ──────────────────────────────────────────────────
# JWT secret for signing auth tokens (leave empty for auto-generated)
# IMPORTANT: set a stable value in production to persist sessions across restarts
DBMANAGER_JWT_SECRET=
# Master encryption key for sensitive data at rest
DBMANAGER_MASTER_KEY=

# ── CLI ───────────────────────────────────────────────────────
# Enable interactive CLI in the backend container (default: false)
# Set to true only if you need the terminal interface
DBMANAGER_ENABLE_CLI=false

# ── Reverse proxy (Caddy) ─────────────────────────────────────
# Master switch for the proxy service.
DBMANAGER_PROXY_ENABLED=true
# Skip the interactive wizard inside the container (recommended in compose deploys).
DBMANAGER_PROXY_NONINTERACTIVE=true
# Mode: http | https | disabled
DBMANAGER_PROXY_MODE=http
# Domain to serve. For local dev set to "localhost".
DBMANAGER_PROXY_DOMAIN=localhost
# Host ports the caddy container binds (override if 80/443 are taken).
DBMANAGER_PROXY_HTTP_PORT=80
DBMANAGER_PROXY_HTTPS_PORT=443

# ACME (only if mode=https)
#   dns        → DNS-01 via plugin (set DBMANAGER_PROXY_DNS_PROVIDER + provider env)
#   http-01    → HTTP-01 challenge (requires public port 80)
#   manual     → user-supplied cert + key files
#   selfsigned → caddy `tls internal` (dev only)
DBMANAGER_PROXY_ACME_METHOD=
DBMANAGER_PROXY_ACME_EMAIL=
# DNS provider: cloudflare | route53 | digitalocean | gandi | duckdns
DBMANAGER_PROXY_DNS_PROVIDER=
# Manual cert paths (mounted into the caddy container)
DBMANAGER_PROXY_CERT_PATH=
DBMANAGER_PROXY_KEY_PATH=

# DNS provider credentials — set only the one matching DBMANAGER_PROXY_DNS_PROVIDER
CF_API_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
DO_AUTH_TOKEN=
GANDI_API_TOKEN=
DUCKDNS_API_TOKEN=

# ── Test Infrastructure ───────────────────────────────────────
# PostgreSQL
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=testdb

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=testdb
MYSQL_USER=testuser
MYSQL_PASSWORD=testpassword

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
